# Google Cloud Project Credentials
# Obtain these from the Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# VAPID Keys for Web Push Notifications
# You can generate these using the 'vapid' CLI tool installed in the virtual environment:
# source venv/bin/activate
# vapid --gen
# vapid --private-key private_key.pem --applicationServerKey
#
# Alternatively, use this Python one-liner to get both in the correct Base64 URL format:
# ./venv/bin/python3 -c "import base64; from cryptography.hazmat.primitives import serialization; from py_vapid import Vapid; v = Vapid(); v.generate_keys(); pub_raw = v.public_key.public_numbers().encode_point(); priv_raw = v.private_key.private_numbers().private_value.to_bytes(32, 'big'); print('VAPID_PUBLIC_KEY=' + base64.urlsafe_b64encode(pub_raw).decode().strip('=')); print('VAPID_PRIVATE_KEY=' + base64.urlsafe_b64encode(priv_raw).decode().strip('='))"

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optional: Enable permanent deletion scope
# Requires re-authentication if changed
# ENABLE_DELETION_SCOPE=true
